{
  "configVersion": "1.0",
  "description": "Migrate mock store items",
  "source": {
    "database": "store_db",
    "table": "items",
    "query": "SELECT * FROM items WHERE store_id = :storeId AND update_date = :updateDate",
    "params": [
      { "name": "storeId", "type": "string", "value": "S001" },
      { "name": "updateDate", "type": "date", "value": "2026-07-17" }
    ]
  },
  "target": {
    "database": "central_db",
    "table": "items_archive",
    "deleteCondition": {
      "conditions": [
        { "column": "STORE_ID", "operator": "=", "value": "$ref:storeId" }
      ]
    }
  }
}
